<div id="ev-ai-root">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    #ev-ai-root {
      --ev-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --ev-panel-bg: linear-gradient(155deg, rgba(19, 25, 35, 0.96) 0%, rgba(10, 13, 19, 0.99) 100%);
      --ev-panel-border: rgba(255, 255, 255, 0.1);
      --ev-text-main: #ffffff;
      --ev-text-muted: #9aa7bc;
      --ev-accent: #00ff7f;
      --ev-accent-2: #0de3ff;
      --ev-accent-warm: #ffd447;
      --ev-accent-glow: rgba(0, 255, 127, 0.38);
      --ev-card-bg: rgba(255, 255, 255, 0.04);
      --ev-card-border: rgba(255, 255, 255, 0.08);
      --ev-orb-gradient: radial-gradient(circle at 30% 20%, #2b3142 0%, #171d28 56%, #0e1118 100%);
      --ev-hover-card: rgba(255, 255, 255, 0.09);
      --ev-z: 2147483647;
      
      font-family: var(--ev-font);
      box-sizing: border-box;
    }

    #ev-ai-root * {
      box-sizing: border-box;
      margin: 0; padding: 0;
    }

    /* -------------------------------------- */
    /* 1. THE LAUNCHER CONTAINER (THE ORB)    */
    /* -------------------------------------- */
    .ev-ai-launcher-wrapper {
      position: fixed;
      bottom: 24px; right: 24px;
      z-index: var(--ev-z);
      display: flex; flex-direction: column; align-items: flex-end; gap: 12px;
      filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.45));
      animation: ev-widget-float 4.2s ease-in-out infinite;
    }

    /* Small transcript bubble above orb */
    .ev-ai-transcript-bubble {
      position: relative;
      background:
        radial-gradient(circle at 0% 0%, rgba(13, 227, 255, 0.16) 0%, transparent 42%),
        radial-gradient(circle at 100% 100%, rgba(0, 255, 127, 0.16) 0%, transparent 36%),
        var(--ev-panel-bg);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      border: 1px solid rgba(255, 255, 255, 0.16);
      color: var(--ev-text-main);
      padding: 12px 14px;
      border-radius: 14px;
      box-shadow: 0 14px 40px rgba(0,0,0,0.48);
      font-size: 13px;
      max-width: 320px;
      text-align: left;
      line-height: 1.45;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.34s ease, transform 0.34s ease;
      transform: translateY(12px) scale(0.97);
    }
    .ev-ai-transcript-bubble.ev-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
    }

    .ev-ai-transcript-bubble:after {
      content: "";
      position: absolute;
      right: 22px;
      bottom: -8px;
      width: 14px;
      height: 14px;
      transform: rotate(45deg);
      background: #141b26;
      border-right: 1px solid rgba(255,255,255,0.18);
      border-bottom: 1px solid rgba(255,255,255,0.18);
    }

    .ev-ai-launcher-wrapper:hover .ev-ai-transcript-bubble {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    
    .ev-ai-status-indicator {
      font-size: 10px;
      color: var(--ev-text-muted);
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 4px;
    }
    
    .ev-ai-status-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--ev-accent); box-shadow: 0 0 12px var(--ev-accent);
      animation: ev-pulse-dot 1.6s ease-in-out infinite;
    }

    /* The floating orb button itself */
    .ev-ai-launcher-btn {
      width: 70px; height: 70px;
      border-radius: 50%;
      background:
        radial-gradient(circle at 25% 20%, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0.01) 33%),
        radial-gradient(circle at 70% 82%, rgba(0,255,127,0.1) 0%, rgba(0,255,127,0) 42%),
        var(--ev-orb-gradient);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.2);
      color: var(--ev-text-main);
      box-shadow:
        0 8px 28px rgba(0,0,0,0.55),
        0 0 0 1px rgba(255,255,255,0.07) inset,
        0 0 24px var(--ev-accent-glow);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
      position: relative;
      overflow: hidden;
      animation: ev-orb-glow 2.8s ease-in-out infinite;
    }

    .ev-ai-launcher-btn:before {
      content: "";
      position: absolute;
      inset: -24%;
      background:
        conic-gradient(from 40deg, rgba(13,227,255,0) 0%, rgba(13,227,255,0.36) 30%, rgba(0,255,127,0.35) 55%, rgba(255,212,71,0.28) 72%, rgba(13,227,255,0) 100%);
      filter: blur(12px);
      opacity: 0.7;
      animation: ev-rotor 7s linear infinite;
      pointer-events: none;
    }

    .ev-ai-launcher-btn:after {
      content: "";
      position: absolute;
      inset: 15%;
      border-radius: 50%;
      border: 1.5px dashed rgba(255,255,255,0.2);
      pointer-events: none;
      animation: ev-ball-spin 16s linear infinite;
    }

    .ev-ai-launcher-btn:hover {
      transform: translateY(-4px) scale(1.07);
      border-color: rgba(13,227,255,0.8);
      box-shadow:
        0 14px 42px rgba(0,0,0,0.6),
        0 0 26px rgba(13,227,255,0.45),
        0 0 36px rgba(0,255,127,0.35);
    }
    .ev-ai-launcher-btn svg {
      width: 44px; height: 44px;
      transition: opacity 0.3s;
      z-index: 2;
      filter: drop-shadow(0 0 8px rgba(255,255,255,0.22));
    }

    .ev-ai-mic-icon {
      stroke-width: 1.8;
    }
    
    /* Recording / Listening State for Orb */
    .ev-ai-launcher-btn.ev-listening {
      border-color: var(--ev-accent-2);
      box-shadow:
        0 0 0 1px rgba(13,227,255,0.6) inset,
        0 0 34px rgba(13, 227, 255, 0.52),
        0 0 54px rgba(13, 227, 255, 0.25);
    }
    .ev-ai-launcher-btn.ev-speaking {
      border-color: var(--ev-accent);
      box-shadow:
        0 0 0 1px rgba(0,255,127,0.65) inset,
        0 0 34px rgba(0,255,127,0.52),
        0 0 58px rgba(0,255,127,0.26);
    }
    
    /* Close icon inside orb */
    .ev-ai-close-icon {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      opacity: 0;
      width: 26px !important; height: 26px !important;
    }
    .ev-ai-launcher-btn.ev-active .ev-ai-mic-icon { opacity: 0; }
    .ev-ai-launcher-btn.ev-active .ev-ai-close-icon { opacity: 1; }
    
    /* Orb mini visualizer */
    .ev-ai-mini-bars {
      position: absolute;
      bottom: -13px;
      display: flex; gap: 2px; height: 12px; align-items: center; margin: 4px 0;
      opacity: 0;
      transition: opacity 0.3s;
      z-index: 3;
    }
    .ev-ai-launcher-btn.ev-active .ev-ai-mini-bars { opacity: 1; }
    .ev-ai-mini-bar {
      width: 3px;
      background: linear-gradient(180deg, var(--ev-accent-2), var(--ev-accent));
      border-radius: 2px;
      box-shadow: 0 0 8px rgba(13,227,255,0.45);
      animation: ev-mini-bounce 0.8s infinite ease-in-out;
    }
    .ev-ai-mini-bar:nth-child(1) { height: 4px; animation-delay: 0s; }
    .ev-ai-mini-bar:nth-child(2) { height: 8px; animation-delay: 0.1s; }
    .ev-ai-mini-bar:nth-child(3) { height: 12px; animation-delay: 0.2s; background: linear-gradient(180deg, var(--ev-accent-warm), var(--ev-accent)); }
    .ev-ai-mini-bar:nth-child(4) { height: 8px; animation-delay: 0.3s; }
    .ev-ai-mini-bar:nth-child(5) { height: 4px; animation-delay: 0.4s; }

    @keyframes ev-mini-bounce { 0%, 100% { transform: scaleY(0.5); } 50% { transform: scaleY(1); } }
    @keyframes ev-widget-float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
    @keyframes ev-orb-glow {
      0%, 100% { box-shadow: 0 8px 28px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.07) inset, 0 0 22px rgba(0,255,127,0.24); }
      50% { box-shadow: 0 10px 34px rgba(0,0,0,0.58), 0 0 0 1px rgba(255,255,255,0.12) inset, 0 0 34px rgba(13,227,255,0.32), 0 0 42px rgba(0,255,127,0.26); }
    }
    @keyframes ev-rotor { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes ev-ball-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes ev-pulse-dot {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.18); opacity: 0.85; }
    }

    @media (max-width: 640px) {
      .ev-ai-launcher-wrapper { right: 16px; bottom: 16px; }
      .ev-ai-launcher-btn { width: 64px; height: 64px; }
      .ev-ai-transcript-bubble { max-width: 260px; font-size: 12px; }
    }

    /* -------------------------------------- */
    /* 2. THE SIDE PANEL (DOM INJECTION)      */
    /* -------------------------------------- */
    .ev-ai-side-panel {
      position: fixed;
      left: 50%;
      right: auto;
      top: auto;
      bottom: 10px;
      transform: translateX(-50%) translateY(105%);
      width: min(1240px, calc(100vw - 14px));
      height: min(88vh, 940px);
      max-width: 100vw;
      border-radius: 22px 22px 0 0;
      overflow: auto;
      background:
        radial-gradient(circle at 8% 0%, rgba(13, 227, 255, 0.16) 0%, transparent 30%),
        radial-gradient(circle at 92% 100%, rgba(0, 255, 127, 0.16) 0%, transparent 36%),
        linear-gradient(150deg, rgba(16, 23, 35, 0.98) 0%, rgba(10, 15, 24, 0.98) 50%, rgba(7, 11, 18, 0.99) 100%);
      backdrop-filter: blur(30px) saturate(145%);
      -webkit-backdrop-filter: blur(30px) saturate(145%);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow:
        0 -20px 60px rgba(0,0,0,0.62),
        0 0 40px rgba(13,227,255,0.16),
        0 0 56px rgba(0,255,127,0.14);
      z-index: calc(var(--ev-z) - 1);
      display: flex;
      flex-direction: column;
      transition: transform 0.46s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.35s ease;
      animation: ev-panel-glow 4.2s ease-in-out infinite;
      min-width: 420px;
      min-height: 500px;
      max-width: calc(100vw - 12px);
      max-height: 94vh;
    }
    .ev-ai-side-panel.ev-open {
      transform: translateX(-50%) translateY(0);
    }

    .ev-ai-panel-header {
      padding: 18px 22px;
      border-bottom: 1px solid rgba(255,255,255,0.14);
      display: flex; justify-content: space-between; align-items: center;
      background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0));
    }
    .ev-ai-panel-header h2 {
      position: relative;
      max-width: calc(100% - 56px);
      font-size: clamp(20px, 2.6vw, 34px);
      font-weight: 700;
      color: #f4f8ff;
      letter-spacing: 0.3px;
      line-height: 1.15;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      background: linear-gradient(90deg, #eaf4ff 0%, #8ff9c1 45%, #82ecff 70%, #eaf4ff 100%);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 14px rgba(13,227,255,0.2);
      animation: ev-heading-shift 5.8s linear infinite;
    }
    .ev-ai-panel-header h2:after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -5px;
      width: 58%;
      height: 2px;
      border-radius: 6px;
      background: linear-gradient(90deg, rgba(13,227,255,0.95), rgba(0,255,127,0.82), rgba(255,212,71,0.8));
      box-shadow: 0 0 14px rgba(13,227,255,0.28);
      animation: ev-header-line 2.8s ease-in-out infinite;
    }
    .ev-ai-close-panel-btn {
      width: 40px;
      height: 40px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.05);
      color: #c8d5ea;
      font-size: 26px;
      line-height: 1;
      cursor: pointer;
      transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
    }
    .ev-ai-close-panel-btn:hover {
      color: #fff;
      background: rgba(13,227,255,0.16);
      transform: rotate(90deg) scale(1.06);
    }

    .ev-ai-panel-content {
      flex: 1; overflow-y: auto; 
      padding: 20px 22px 120px;
      display: flex; flex-direction: column; gap: 16px;
      min-height: 0;
    }
    .ev-ai-panel-content::-webkit-scrollbar { width: 9px; }
    .ev-ai-panel-content::-webkit-scrollbar-track { background: transparent; }
    .ev-ai-panel-content::-webkit-scrollbar-thumb {
      background: linear-gradient(180deg, rgba(13,227,255,0.38), rgba(0,255,127,0.38));
      border-radius: 12px;
      border: 2px solid rgba(0,0,0,0.25);
    }

    /* Product Grid / Details inside Side Panel */
    .ev-ai-product-card {
      background:
        linear-gradient(132deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0.03) 100%),
        var(--ev-card-bg);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 16px;
      padding: 14px;
      display: flex; gap: 12px;
      align-items: center;
      transition: transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
      box-shadow: 0 8px 24px rgba(0,0,0,0.26);
    }
    .ev-ai-product-card:hover {
      transform: translateY(-3px);
      border-color: rgba(13,227,255,0.42);
      box-shadow: 0 14px 30px rgba(0,0,0,0.34), 0 0 20px rgba(13,227,255,0.14);
      background: var(--ev-hover-card);
    }
    .ev-ai-img-box {
      width: clamp(78px, 9.4vw, 108px);
      height: clamp(78px, 9.4vw, 108px);
      border-radius: 12px;
      flex-shrink: 0;
      border: 1px solid rgba(255,255,255,0.16);
      background: rgba(255,255,255,0.05);
      display: flex; align-items: center; justify-content: center; padding: 4px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.25);
    }
    .ev-ai-img-box img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 10px;
    }
    .ev-ai-card-info {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 8px;
      flex: 1;
    }
    .ev-ai-card-title {
      font-size: clamp(18px, 2.2vw, 32px);
      font-weight: 700;
      color: #f5f9ff;
      line-height: 1.25;
      letter-spacing: 0.2px;
      text-shadow: 0 0 8px rgba(13,227,255,0.15);
    }
    .ev-ai-card-price {
      font-size: clamp(16px, 1.8vw, 26px);
      font-weight: 700;
      color: #8df8bf;
    }
    
    .ev-ai-btn-primary {
      padding: 14px 18px !important;
      border: 1px solid rgba(255,255,255,0.24);
      border-radius: 12px;
      background: linear-gradient(135deg, #0de3ff 0%, #00ff7f 50%, #ffd447 100%);
      color: #06121b;
      font-size: 16px !important;
      font-weight: 800;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
      width: 100%;
      text-align: center;
      text-transform: uppercase;
      box-shadow: 0 10px 22px rgba(0,0,0,0.25), 0 0 20px rgba(0,255,127,0.2);
    }
    .ev-ai-btn-primary:hover {
      transform: translateY(-2px) scale(1.02);
      filter: brightness(1.05);
      box-shadow: 0 14px 28px rgba(0,0,0,0.3), 0 0 26px rgba(13,227,255,0.3);
    }
    
    .ev-ai-btn-secondary {
      padding: 12px 16px !important;
      border: 1px solid rgba(13,227,255,0.4);
      border-radius: 11px;
      background: linear-gradient(135deg, rgba(13,227,255,0.16), rgba(0,255,127,0.12));
      color: #f5fbff;
      font-size: 15px !important;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      text-decoration: none;
    }
    .ev-ai-btn-secondary:hover {
      transform: translateY(-1px);
      background: linear-gradient(135deg, rgba(13,227,255,0.26), rgba(0,255,127,0.22));
      box-shadow: 0 0 20px rgba(13,227,255,0.25);
    }

    #ev-ai-stage > div > img {
      width: 100% !important;
      min-height: 220px !important;
      max-height: clamp(320px, 52vh, 600px) !important;
      object-fit: contain !important;
      object-position: center !important;
      border-radius: 16px !important;
      margin-bottom: 18px !important;
      border: 1px solid rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.02);
      box-shadow: 0 14px 28px rgba(0,0,0,0.34);
    }

    #ev-ai-stage > div > h3 {
      font-size: clamp(21px, 3.2vw, 34px) !important;
      font-weight: 800 !important;
      line-height: 1.2 !important;
      margin-bottom: 10px !important;
    }

    #ev-ai-stage > div > p {
      font-size: clamp(14px, 1.35vw, 18px) !important;
      line-height: 1.55 !important;
    }

    @keyframes ev-heading-shift {
      0% { background-position: 0% 50%; }
      100% { background-position: 220% 50%; }
    }
    @keyframes ev-header-line {
      0%, 100% { opacity: 0.65; transform: scaleX(0.94); transform-origin: left; }
      50% { opacity: 1; transform: scaleX(1.05); transform-origin: left; }
    }

    @keyframes ev-panel-glow {
      0%, 100% {
        box-shadow: 0 -20px 60px rgba(0,0,0,0.62), 0 0 34px rgba(13,227,255,0.14), 0 0 46px rgba(0,255,127,0.12);
      }
      50% {
        box-shadow: 0 -20px 60px rgba(0,0,0,0.62), 0 0 44px rgba(13,227,255,0.2), 0 0 60px rgba(0,255,127,0.18);
      }
    }

    @media (max-width: 900px) {
      .ev-ai-side-panel {
        width: calc(100vw - 8px);
        height: min(90vh, 860px);
        min-width: 300px;
        min-height: 420px;
      }
      .ev-ai-panel-content { padding-bottom: 110px; }
    }

  </style>

