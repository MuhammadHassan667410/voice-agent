  <script>
    var EV_VAPI_PUBLIC_KEY = 'e92c4f5a-6b3d-4975-813c-ecc90a66eea2';
    var EV_VAPI_ASSISTANT_ID = 'b0969356-05e8-40c4-ae11-6bb3d25b9ef7';

    window.evAiInit = function() {
      // --------------------------------------
      // 1. REACTIVE STATE MANAGER
      // --------------------------------------
      var state = {
        isCallActive: false,
        isPanelOpen: false,
        vapiStatus: 'disconnected', // disconnected | connecting | listening | speaking
        view: 'search_results',
        products: [],
        cartItems: [],
        transcript: ''
      };

      // --------------------------------------
      // 2. DOM ELEMENT BINDINGS
      // --------------------------------------
      var els = {
        launcherBtn:  document.getElementById('ev-ai-launcher-btn'),
        transcriptBubble: document.getElementById('ev-ai-transcript-bubble'),
        transcriptText: document.getElementById('ev-ai-transcript-text'),
        statusIndicator: document.getElementById('ev-ai-status-indicator'),
        sidePanel:    document.getElementById('ev-ai-side-panel'),
        panelTitle:   document.getElementById('ev-ai-panel-title'),
        closePanelBtn:document.getElementById('ev-ai-close-panel-btn'),
        stage:        document.getElementById('ev-ai-stage')
      };

      if (!els.launcherBtn || !els.sidePanel) return;

      // --------------------------------------
      // 3. UI RENDER ENGINE
      // --------------------------------------
      function render() {
        // --- Orb State ---
        if (state.isCallActive) {
          els.launcherBtn.classList.add('ev-active');
          els.transcriptBubble.classList.add('ev-visible');
        } else {
          els.launcherBtn.classList.remove('ev-active');
          els.transcriptBubble.classList.remove('ev-visible');
        }

        els.launcherBtn.classList.remove('ev-listening', 'ev-speaking');
        if (state.vapiStatus === 'listening') els.launcherBtn.classList.add('ev-listening');
        if (state.vapiStatus === 'speaking') els.launcherBtn.classList.add('ev-speaking');

        // --- Status Indicators ---
        var statusMap = {
          disconnected: { text: 'READY', color: '#8b96a5' },
          connecting:   { text: 'CONNECTING...', color: '#f0a500' },
          listening:    { text: 'LISTENING...', color: '#00f2fe' },
          speaking:     { text: 'SPEAKING...', color: 'var(--ev-accent)' }
        };
        var s = statusMap[state.vapiStatus] || statusMap.disconnected;
        els.statusIndicator.innerHTML = s.text + ' <span class="ev-ai-status-dot" style="background:' + s.color + ';box-shadow:0 0 8px ' + s.color + '"></span>';
        
        if (state.transcript) els.transcriptText.textContent = state.transcript;

        // --- Side Panel Visibility ---
        if (state.isPanelOpen) {
          els.sidePanel.classList.add('ev-open');
        } else {
          els.sidePanel.classList.remove('ev-open');
        }

        renderStage();

        // --- Delegate click events ---
        els.stage.onclick = function(e) {
          var btn = e.target.closest('[data-ev-action]');
          if (!btn) return;
          var evAction = btn.getAttribute('data-ev-action');
          var id = btn.getAttribute('data-id') || '';
          var variantId = btn.getAttribute('data-variant') || '';
          var qty = parseInt(btn.getAttribute('data-qty') || '1', 10);

          if (evAction === 'add-to-cart') addToShopifyCart(variantId || id, qty);
          else if (evAction === 'remove-from-cart') updateShopifyCart(id, 0);
          else if (evAction === 'update-qty') updateShopifyCart(id, qty);
          else if (evAction === 'open-product') openProductById(id);
        };
      }

      function renderStage() {
        if (!state.isPanelOpen) return;

        if (state.view === 'search_results' && state.products.length > 0) {
          els.panelTitle.textContent = 'Products Found';
          var html = '';
          state.products.forEach(function(p, idx) {
            var imgSrc = (p.images && p.images[0]) || p.image || '';
            var priceText = (typeof p.price === 'number') ? ('$' + p.price.toFixed(2)) : (p.price || '$0.00');
            var productId = p.product_id || p.id || '';
            html += '<div class="ev-ai-product-card">' +
              (imgSrc ? '<div class="ev-ai-img-box"><img src="' + imgSrc + '"></div>' : '') +
              '<div class="ev-ai-card-info">' +
                '<span class="ev-ai-card-title">' + (p.title || 'Product') + '</span>' +
                '<span class="ev-ai-card-price">' + priceText + '</span>' +
                '<button class="ev-ai-btn-secondary" style="margin-top:6px;width:fit-content;" data-ev-action="open-product" data-id="' + productId + '">View Details</button>' +
              '</div>' +
            '</div>';
          });
          els.stage.innerHTML = html;
        }
        else if (state.view === 'product_detail' && state.products.length > 0) {
          els.panelTitle.textContent = 'Product Details';
          var p = state.products[0];
          var imgSrc = (p.images && p.images[0]) || p.image || '';
          var priceText = (typeof p.price === 'number') ? ('$' + p.price.toFixed(2)) : (p.price || '');
          var variants = p.variants || [];
          var productId = p.product_id || p.id || '';

          var variantHtml = '';
          if (variants.length > 0) {
            variantHtml = '<div style="margin:12px 0;display:flex;flex-wrap:wrap;gap:8px;">';
            variants.forEach(function(v) {
              var vId = v.variant_id || v.id || '';
              // Extract purely numeric ID if it's a GID
              if (typeof vId === 'string') {
                var m = vId.match(/(\d+)$/);
                if (m) vId = m[1];
              }
              var vTitle = v.title || 'Default';
              var vAvail = v.available !== false;
              variantHtml += '<button class="ev-ai-btn-primary" data-ev-action="add-to-cart" data-variant="' + vId + '" data-qty="1" ' +
                'style="flex:1;min-width:60px;font-size:11px;' + (vAvail ? '' : 'opacity:0.4;cursor:not-allowed;') + '"' +
                (vAvail ? '' : ' disabled') + '>Add ' + vTitle + '</button>';
            });
            variantHtml += '</div>';
          } else {
            // No variants — use product ID or default ID as numeric variant
            var vId = productId;
            if (typeof vId === 'string') {
                var m = vId.match(/(\d+)$/);
                if (m) vId = m[1];
            }
            variantHtml = '<button class="ev-ai-btn-primary" data-ev-action="add-to-cart" data-variant="' + vId + '" data-qty="1" style="margin-top:12px;">ADD TO CART</button>';
          }

          els.stage.innerHTML = '<div>' +
            (imgSrc ? '<img src="' + imgSrc + '" style="width:100%;max-height:250px;object-fit:contain;border-radius:12px;margin-bottom:16px;background:rgba(255,255,255,0.02);">' : '') +
            '<h3 style="color:#fff;font-size:18px;margin-bottom:8px;">' + (p.title || 'Product') + '</h3>' +
            '<p style="color:var(--ev-accent);font-size:16px;font-weight:600;margin-bottom:12px;">' + priceText + '</p>' +
            (p.short_description ? '<p style="color:var(--ev-text-muted);font-size:13px;line-height:1.5;margin-bottom:16px;">' + p.short_description + '</p>' : '') +
            variantHtml +
          '</div>';
        }
        else if (state.view === 'cart') {
          els.panelTitle.textContent = 'Your Cart';
          if (state.cartItems && state.cartItems.length > 0) {
            var cartHtml = '<div>';
            var cartTotal = 0;
            state.cartItems.forEach(function(item) {
              var linePrice = (item.line_price || item.price || 0) / 100;
              cartTotal += linePrice;
              cartHtml += '<div class="ev-ai-product-card" style="margin-bottom:12px;align-items:center;">' +
                (item.image ? '<div class="ev-ai-img-box" style="width:60px;height:60px;"><img src="' + item.image + '"></div>' : '') +
                '<div class="ev-ai-card-info">' +
                  '<span class="ev-ai-card-title">' + (item.title || 'Item') + '</span>' +
                  '<span class="ev-ai-card-price">' + (item.variant_title || '') + ' × ' + item.quantity + '</span>' +
                  '<span style="color:var(--ev-accent);font-size:12px;font-weight:600;">$' + linePrice.toFixed(2) + '</span>' +
                '</div>' +
                '<div style="display:flex;flex-direction:column;gap:4px;">' +
                  '<button class="ev-ai-btn-secondary" style="padding:4px 8px;" data-ev-action="update-qty" data-id="' + item.key + '" data-qty="' + (item.quantity + 1) + '">+</button>' +
                  '<button class="ev-ai-btn-secondary" style="padding:4px 8px;" data-ev-action="update-qty" data-id="' + item.key + '" data-qty="' + Math.max(0, item.quantity - 1) + '">-</button>' +
                '</div>' +
              '</div>';
            });
            cartHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-top:1px solid var(--ev-panel-border);margin-top:16px;">' +
              '<span style="color:#fff;font-size:16px;font-weight:600;">Total</span>' +
              '<span style="color:var(--ev-accent);font-size:18px;font-weight:700;">$' + cartTotal.toFixed(2) + '</span>' +
            '</div>' +
            '<a href="/checkout" class="ev-ai-btn-primary" style="display:block;text-decoration:none;">PROCEED TO CHECKOUT</a>' +
            '</div>';
            els.stage.innerHTML = cartHtml;
          } else {
            els.stage.innerHTML = '<p style="color:var(--ev-text-muted);text-align:center;padding:40px 0;">Your cart is empty.</p>';
          }
        }
      }

      function showToast(message, type) {
        type = type || 'success';
        var toast = document.createElement('div');
        var bgColor = type === 'success' ? 'rgba(31,223,100,0.95)' : type === 'error' ? 'rgba(255,77,77,0.95)' : 'rgba(240,165,0,0.95)';
        toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:2147483647;padding:12px 20px;border-radius:8px;color:#000;font-family:var(--ev-font);font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.4);transform:translateY(-20px);opacity:0;transition:all 0.3s;background:' + bgColor + ';';
        toast.textContent = message;
        document.body.appendChild(toast);
        requestAnimationFrame(function() {
          toast.style.transform = 'translateY(0)';
          toast.style.opacity = '1';
        });
        setTimeout(function() {
          toast.style.transform = 'translateY(-20px)';
          toast.style.opacity = '0';
          setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 350);
        }, 3000);
      }

      // --------------------------------------
      // 4. SHOPIFY CART API INTEGRATION
      // --------------------------------------
      function addToShopifyCart(variantId, quantity) {
        if (!variantId) { showToast('No variant selected.', 'error'); return; }
        
        // Ensure numeric variant ID
        var numericVariantId = parseInt(variantId, 10);
        if (typeof variantId === 'string') {
          var match = variantId.match(/(\d+)$/);
          if (match) numericVariantId = parseInt(match[1], 10);
        }

        if (isNaN(numericVariantId) || !numericVariantId) {
            console.log('[EvangelistaAI] Aborting addToShopifyCart: Invalid Variant ID', variantId);
            return;
        }

        quantity = quantity || 1;
        
        // Use standard add.js behavior format
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: numericVariantId, quantity: quantity })
        })
        .then(function(res) {
          if (!res.ok) throw new Error('Shopify returned ' + res.status);
          return res.json();
        })
        .then(function(data) {
          showToast('Added to cart! ✓', 'success');
          updateThemeCartCount();
          // Optionally, auto-open cart to show user what happened
          fetchAndShowCart();
        })
        .catch(function(err) {
          console.error('[EvangelistaAI] Cart add error:', err);
          showToast('Failed to add to cart.', 'error');
        });
      }

      function updateShopifyCart(lineKey, quantity) {
        if (!lineKey) return;
        var updates = {};
        // If the key is a GID, extract numeric ID.
        if (typeof lineKey === 'string' && lineKey.indexOf('gid://') !== -1) {
             var m = lineKey.match(/(\d+)$/);
             if (m) lineKey = m[1];
        }
        updates[lineKey] = quantity;

        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ updates: updates })
        })
        .then(function(res) {
          if (!res.ok) throw new Error('Shopify returned ' + res.status);
          return res.json();
        })
        .then(function() {
          if (quantity === 0) showToast('Removed from cart.', 'success');
          else showToast('Cart updated! ✓', 'success');
          if (state.view === 'cart' && state.isPanelOpen) fetchAndShowCart();
          updateThemeCartCount();
        })
        .catch(function(err) {
          console.error('[EvangelistaAI] Cart update error:', err);
          showToast('Failed to update cart.', 'error');
        });
      }

      function fetchAndShowCart() {
        fetch('/cart.js')
        .then(function(res) { return res.json(); })
        .then(function(cart) {
          state.cartItems = (cart.items || []).map(function(item) {
            return {
              key: item.key, // Can be variant_id or a unique key string (which is correct for /cart/update.js)
              variant_id: item.variant_id,
              title: item.title,
              variant_title: item.variant_title || '',
              quantity: item.quantity,
              price: item.price,
              line_price: item.line_price || (item.price * item.quantity),
              image: item.image || (item.featured_image && item.featured_image.url) || ''
            };
          });
          state.view = 'cart';
          state.isPanelOpen = true;
          render();
        })
        .catch(function(err) {
          showToast('Could not load cart.', 'error');
        });
      }

      function updateThemeCartCount() {
        try {
          fetch('/cart.js')
          .then(function(res) { return res.json(); })
          .then(function(cart) {
            var countEls = document.querySelectorAll('[data-cart-count], .cart-count-bubble span, .cart-count, .js-cart-count');
            countEls.forEach(function(el) { el.textContent = cart.item_count; });
            
            // Many modern themes (like Dawn) have a cart drawer that can be triggered.
            // Dispatch standard cart update event
            document.documentElement.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true }));
          });
        } catch(e) {}
      }

      function openProductById(productId) {
        if (!productId) return;
        var numericProductId = typeof productId === 'string' && productId.indexOf('gid://') !== -1 ? productId.split('/').pop() : productId;
        var encodedOriginalId = encodeURIComponent(productId);
        var encodedNumericId = encodeURIComponent(String(numericProductId || ''));

        function fetchProductDetailsById() {
          var backendUrl = window.EV_BACKEND_URL || 'https://muhammadhassan.tech';
          return fetch(backendUrl + '/product/' + encodedOriginalId)
            .then(function(res) {
              if (res.ok) return res.json();
              if (res.status === 404 && encodedNumericId && encodedNumericId !== encodedOriginalId) {
                return fetch(backendUrl + '/product/' + encodedNumericId).then(function(secondRes) {
                  if (!secondRes.ok) throw new Error('Product lookup failed with status ' + secondRes.status);
                  return secondRes.json();
                });
              }
              throw new Error('Product lookup failed with status ' + res.status);
            });
        }
        
        // Try cache first
        var found = null;
        state.products.forEach(function(p) {
          var pId = p.product_id || p.id || '';
          var pNumId = typeof pId === 'string' && pId.indexOf('gid://') !== -1 ? pId.split('/').pop() : pId;
          if (pId === productId || pNumId === numericProductId) found = p;
        });

        if (found && found.title && found.title.indexOf('Loading') === -1 && found.title.indexOf('unavailable') === -1) {
          state.products = [found];
          state.view = 'product_detail';
          state.isPanelOpen = true;
          render();
        } else {
          // Temporarily show loading state.
          state.view = 'product_detail';
          state.products = [{ product_id: productId, title: 'Loading product details...', price: '...' }];
          state.isPanelOpen = true;
          render();

          // Independent frontend fetch logic since Vapi Web SDK doesn't natively forward server webhook responses
          fetchProductDetailsById()
            .then(function(data) {
                if (data && data.item) {
                    state.products = [data.item];
                    render();
                } else {
                    state.products = [{ product_id: productId, title: 'Product details unavailable.', price: '' }];
                    render();
                }
            })
            .catch(function(err) {
                console.error('[EvangelistaAI] Failed to fetch product details:', err);
                state.products = [{ product_id: productId, title: 'Failed to load details.', price: '' }];
                render();
            });
        }
      }

      // --------------------------------------
      // 5. ACTION ROUTER
      // --------------------------------------
      window.handleAction = function(action) {
        if (!action || !action.type) return;
        var payload = action.payload || {};
        if (typeof payload === 'string') {
          try { payload = JSON.parse(payload); } catch (e) { payload = {}; }
        }
        if (!payload || typeof payload !== 'object') payload = {};

        switch (action.type) {
          case 'search_products':
            var q = payload.query || '';
            state.view = 'search_results';

            var candidates = Array.isArray(payload.candidates) ? payload.candidates : [];
            var items = Array.isArray(payload.items) ? payload.items : [];
            var searchResults = candidates.length > 0 ? candidates : items;

            if (searchResults.length > 0) {
                state.products = searchResults;
                state.isPanelOpen = true;
                if (els.panelTitle) els.panelTitle.textContent = (state.products.length === 1) ? 'Found 1 Product' : 'Search Results';
                render();
            } else if (q) {
                state.products = [];
                state.isPanelOpen = true;
                if (els.panelTitle) els.panelTitle.textContent = 'Searching ' + q + '...';
                render();
                
                var searchBackendUrl = window.EV_BACKEND_URL || 'https://muhammadhassan.tech';
                fetch(searchBackendUrl + '/search-products', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ query: q, pagination: { limit: 5 } })
                })
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data && data.items && data.items.length > 0) {
                        state.products = data.items;
                        state.lastSearchProducts = data.items;
                        render();
                    } else {
                        if (els.panelTitle) els.panelTitle.textContent = 'No results found.';
                        render();
                    }
                })
                .catch(function(err) {
                    console.error('[EvangelistaAI] Failed to fetch search results:', err);
                    if (els.panelTitle) els.panelTitle.textContent = 'Search failed.';
                    render();
                });
            }
            break;
          case 'open_product':
            var pid = payload.product_id || payload.id || '';
            var payloadItem = (payload.item && typeof payload.item === 'object') ? payload.item : null;
            if (payloadItem && payloadItem.title) {
              state.products = [payloadItem];
              state.view = 'product_detail';
              state.isPanelOpen = true;
              render();
            } else if (payload.title && (payload.variants || payload.images || payload.price !== undefined)) {
              state.products = [payload];
              state.view = 'product_detail';
              state.isPanelOpen = true;
              render();
            } else if (pid) {
              openProductById(pid);
            }
            break;
          case 'add_to_cart':
            var vid = payload.variant_id || '';
            if (vid) addToShopifyCart(vid, payload.quantity || 1);
            break;
          case 'update_cart':
            var lineKey = payload.line_id || payload.variant_id || '';
            if (lineKey) updateShopifyCart(lineKey, (payload.quantity !== undefined) ? payload.quantity : 1);
            break;
          case 'show_cart':
            fetchAndShowCart();
            break;
          case 'navigate':
            // Instead of reloading, maybe just fetchAndShowCart if page='cart'
            if (payload.page === 'cart') fetchAndShowCart();
            else if (payload.url || payload.page) {
                var pageMap = { 'home': '/', 'collection': '/collections' };
                window.location.href = payload.url || pageMap[payload.page] || '/';
            }
            break;
        }
      };

      // --------------------------------------
      // 6. VAPI SDK & PERMISSIONS
      // --------------------------------------
      if (typeof window.Vapi !== 'function') {
        console.error('[EvangelistaAI] FATAL: window.Vapi is not a constructor.', window.Vapi);
        return;
      }

      var vapiInstance = new window.Vapi(EV_VAPI_PUBLIC_KEY);
      window.vapiInstance = vapiInstance;

      vapiInstance.on('call-start', function() {
        state.isCallActive = true;
        state.vapiStatus = 'listening';
        state.transcript = 'Hello! I am John, how can I help you?';
        render();
      });

      vapiInstance.on('call-end', function() {
        state.isCallActive = false;
        state.vapiStatus = 'disconnected';
        state.transcript = 'Call ended.';
        render();
      });
      
      vapiInstance.on('error', function(error) {
        console.error('[EvangelistaAI] Vapi encountered an error:', error);
        state.isCallActive = false;
        state.vapiStatus = 'disconnected';
        state.transcript = 'Error connecting. Please try again.';
        render();
        showToast('Microphone or connection error. Please refresh and allow mic access.', 'error');
      });

      vapiInstance.on('speech-start', function() { state.vapiStatus = 'speaking'; render(); });
      vapiInstance.on('speech-end', function() { state.vapiStatus = 'listening'; render(); });

      vapiInstance.on('message', function(message) {
        if (message.type === 'transcript' && typeof message.transcript === 'string' && message.transcript.trim()) {
          state.transcript = message.transcript.trim();
          render();
        }

        // Action Extraction
        var actionObj = null;
        function findActionDeep(obj, depth) {
          if (!obj || typeof obj !== 'object' || depth > 5) return null;
          if (obj.action && obj.action.type) return obj.action;
          if (Array.isArray(obj)) {
            for (var i=0; i < obj.length; i++) {
              var f = findActionDeep(obj[i], depth + 1);
              if (f) return f;
            }
            return null;
          }
          var keys = ['message', 'toolCallResult', 'results', 'result', 'toolWithToolCallList', 'toolCall', 'function', 'arguments', 'parameters'];
          for (var j=0; j < keys.length; j++) {
            var val = obj[keys[j]];
            if (val) {
              if (typeof val === 'string' && (val.indexOf('{') === 0 || val.indexOf('[') === 0)) {
                try { val = JSON.parse(val); } catch(e) {}
              }
              var found = findActionDeep(val, depth + 1);
              if (found) return found;
            }
          }
          return null;
        }
        
        // Log all raw Vapi messages to determine exactly what the Web SDK receives from the server
        console.log('[EvangelistaAI] Vapi Message Type:', message.type, message);

        actionObj = findActionDeep(message, 0);

        // Fallback for raw tool call (since Vapi doesn't broadcast backend HTTP responses to the frontend by default)
        if (!actionObj && message.type === 'function-call' && message.functionCall) {
            actionObj = {
                type: message.functionCall.name,
                payload: message.functionCall.parameters || {}
            };
        }
        
        // Additional fallback: If it's a tool call list in an array
        if (!actionObj && message.type === 'tool-calls' && message.toolWithToolCallList) {
             for (var idx = 0; idx < message.toolWithToolCallList.length; idx++) {
                 var tc = message.toolWithToolCallList[idx].toolCall;
                 if (tc && tc.function && tc.function.name) {
                     actionObj = { type: tc.function.name, payload: tc.function.arguments || {} };
                     break;
                 }
             }
        }

        if (actionObj) window.handleAction(actionObj);
      });

      // --------------------------------------
      // 7. EVENTS & LAUNCHER
      // --------------------------------------
      els.launcherBtn.addEventListener('click', function() {
        if (state.isCallActive) {
          vapiInstance.stop();
        } else {
          // Start the call synchronously to satisfy iOS/Safari Web Audio requirements.
          // Vapi's internal Daily.co SDK will handle microphone permissions and 
          // emit an 'error' event if denied.
          state.vapiStatus = 'connecting';
          state.isCallActive = true;
          state.transcript = 'Connecting to John...';
          render();
          vapiInstance.start(EV_VAPI_ASSISTANT_ID);
        }
      });

      els.closePanelBtn.addEventListener('click', function() {
        state.isPanelOpen = false;
        render();
      });

      render();
    };
  </script>
</div>
