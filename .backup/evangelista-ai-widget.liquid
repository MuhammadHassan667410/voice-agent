<!--
  ===========================================
  EVANGELISTA SPORTS AI VOICE WIDGET (GLASSMORPHISM)
  ===========================================
  File: snippets/evangelista-ai-widget.liquid
-->

<div id="ev-ai-root">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

    #ev-ai-root {
      --ev-font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --ev-panel-bg: linear-gradient(155deg, rgba(26, 30, 36, 0.85) 0%, rgba(15, 18, 22, 0.98) 100%);
      --ev-panel-border: rgba(255, 255, 255, 0.08);
      --ev-text-main: #ffffff;
      --ev-text-muted: #8b96a5;
      --ev-accent: #1fdf64;
      --ev-accent-glow: rgba(31, 223, 100, 0.3);
      --ev-card-bg: rgba(255, 255, 255, 0.03);
      --ev-card-border: rgba(255, 255, 255, 0.06);
      --ev-orb-gradient: linear-gradient(135deg, #00f2fe 0%, #1fdf64 100%);
      --ev-z: 2147483647;

      font-family: var(--ev-font);
      box-sizing: border-box;
    }

    #ev-ai-root * {
      box-sizing: border-box;
      margin: 0; padding: 0;
    }

    /* -------------------------------------- */
    /* 1. THE LAUNCHER CONTAINER & TOOLTIP    */
    /* -------------------------------------- */
    .ev-ai-launcher-wrapper {
      position: fixed;
      bottom: 24px; right: 24px;
      z-index: var(--ev-z);
      display: flex; flex-direction: column; align-items: flex-end; gap: 12px;
      transition: opacity 0.3s, transform 0.3s;
    }

    .ev-ai-tooltip {
      background: var(--ev-panel-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--ev-panel-border);
      color: var(--ev-text-main);
      padding: 10px 16px;
      border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      font-size: 13px;
      max-width: 250px;
      text-align: center;
      transition: all 0.3s ease;
      transform-origin: bottom right;
      cursor: default;
    }

    .ev-ai-tooltip-title {
      font-weight: 600;
      color: var(--ev-text-main);
    }

    .ev-ai-tooltip-desc {
      display: none;
      color: var(--ev-text-muted);
      margin-top: 8px;
      line-height: 1.4;
      font-size: 12px;
      text-align: left;
    }

    /* Hover State over the wrapper */
    .ev-ai-launcher-wrapper:hover .ev-ai-tooltip {
      padding: 16px;
    }
    .ev-ai-launcher-wrapper:hover .ev-ai-tooltip-title {
      text-align: left;
      font-size: 14px;
    }
    .ev-ai-launcher-wrapper:hover .ev-ai-tooltip-desc {
      display: block;
      animation: ev-fade-in 0.3s ease forwards;
    }

    @keyframes ev-fade-in { from { opacity: 0; } to { opacity: 1; } }

    /* The floating button itself */
    .ev-ai-launcher-btn {
      width: 60px; height: 60px;
      border-radius: 50%;
      background: var(--ev-panel-bg);
      backdrop-filter: blur(16px);
      border: 1px solid var(--ev-panel-border);
      color: var(--ev-text-main);
      box-shadow: 0 10px 40px rgba(0,0,0,0.5);
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.3s ease;
    }

    .ev-ai-launcher-wrapper:hover .ev-ai-launcher-btn {
      transform: translateY(-2px) scale(1.05);
      border-color: var(--ev-accent);
      box-shadow: 0 12px 40px var(--ev-accent-glow);
    }

    .ev-ai-launcher-btn svg {
      width: 28px; height: 28px;
    }

    /* -------------------------------------- */
    /* 2. THE GLASS PANEL                     */
    /* -------------------------------------- */
    .ev-ai-panel {
      position: fixed;
      bottom: 24px; right: -400px;
      width: 360px;
      height: 780px;
      max-height: 85vh;
      border-radius: 4px;
      background: var(--ev-panel-bg);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
      border: 1px solid var(--ev-panel-border);
      box-shadow: 0 30px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.1);
      z-index: var(--ev-z);
      display: flex; flex-direction: column;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s;
    }
    .ev-ai-panel.ev-open {
      right: 24px;
      opacity: 1;
      pointer-events: all;
    }

    /* Hide scrollbars */
    .ev-ai-panel-inner {
      flex: 1; overflow-y: auto;
      padding: 28px 24px 20px 24px; /* Increased top padding to prevent clipping from border-radius */
      display: flex; flex-direction: column; gap: 24px;
    }
    .ev-ai-panel-inner::-webkit-scrollbar { display: none; }

    /* -------------------------------------- */
    /* 3. TOP HEADER ROW                      */
    /* -------------------------------------- */
    .ev-ai-header-bar {
      display: flex; justify-content: space-between; align-items: center;
      color: var(--ev-text-muted); font-size: 14px; font-weight: 500;
      margin-top: 6px; /* Extra push away from curve */
    }
    .ev-ai-brand { display: flex; align-items: center; gap: 6px; }
    .ev-ai-brand svg { width: 18px; height: 18px; }

    .ev-ai-actions { display: flex; gap: 12px; align-items: center; }
    .ev-ai-actions svg { width: 16px; height: 16px; stroke: currentColor; fill: none; stroke-width: 2; cursor: pointer;}
    .ev-ai-actions button { background: none; border: none; color: inherit; font-size: 20px; cursor: pointer; line-height: 1; padding: 0 4px;}
    .ev-ai-actions button:hover, .ev-ai-actions svg:hover { color: var(--ev-text-main); }

    /* -------------------------------------- */
    /* 4. TITLE ROW & STATUS                  */
    /* -------------------------------------- */
    .ev-ai-title-row {
      display: flex; justify-content: space-between; align-items: center;
    }
    .ev-ai-title-row h2 {
      font-size: 18px; font-weight: 600; color: var(--ev-text-main);
    }
    .ev-ai-status-badge {
      display: flex; align-items: center; gap: 6px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
      color: var(--ev-accent); background: rgba(31, 223, 100, 0.1);
      padding: 4px 8px; border-radius: 20px;
    }
    .ev-ai-status-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--ev-accent); box-shadow: 0 0 8px var(--ev-accent);
    }

    /* -------------------------------------- */
    /* 5. THE ORB (LISTENING VISUALIZER)      */
    /* -------------------------------------- */
    .ev-ai-orb-wrapper {
      display: flex; flex-direction: column; align-items: center; gap: 16px;
      margin: 10px 0;
    }

    .ev-ai-orb {
      position: relative;
      width: 140px; height: 140px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      background: rgba(10, 15, 20, 0.5);
      box-shadow: inset 0 0 20px rgba(0, 242, 254, 0.1);
    }

    .ev-ai-orb::before {
      content: ''; position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px;
      border-radius: 50%; z-index: -1;
      background: var(--ev-orb-gradient);
      box-shadow: 0 0 30px rgba(0, 242, 254, 0.2);
    }

    .ev-ai-orb-inner {
      width: calc(100% - 4px); height: calc(100% - 4px);
      background: var(--ev-panel-bg);
      border-radius: 50%;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 6px;
    }

    .ev-ai-orb-text {
      font-size: 10px; font-weight: 600; letter-spacing: 1px; color: var(--ev-text-muted);
    }

    .ev-ai-mini-bars { display: flex; gap: 2px; height: 12px; align-items: center; margin: 4px 0; }
    .ev-ai-mini-bar { width: 2px; background: #00f2fe; border-radius: 2px; animation: ev-mini-bounce 0.8s infinite ease-in-out; }
    .ev-ai-mini-bar:nth-child(1) { height: 4px; animation-delay: 0s; }
    .ev-ai-mini-bar:nth-child(2) { height: 8px; animation-delay: 0.1s; }
    .ev-ai-mini-bar:nth-child(3) { height: 12px; animation-delay: 0.2s; background: var(--ev-accent); }
    .ev-ai-mini-bar:nth-child(4) { height: 8px; animation-delay: 0.3s; }
    .ev-ai-mini-bar:nth-child(5) { height: 4px; animation-delay: 0.4s; }

    @keyframes ev-mini-bounce { 0%, 100% { transform: scaleY(0.5); } 50% { transform: scaleY(1); } }

    .ev-ai-orb-icon { width: 20px; height: 20px; stroke: var(--ev-text-muted); stroke-width: 2; fill: none;}
    .ev-ai-help-text { font-size: 13px; color: var(--ev-text-muted); text-align: center; }

    /* -------------------------------------- */
    /* 6. PRODUCT RECOMMENDATIONS GRID        */
    /* -------------------------------------- */
    .ev-ai-recs { display: flex; flex-direction: column; gap: 12px; }
    .ev-ai-recs h3 { font-size: 12px; font-weight: 600; color: var(--ev-text-main); }

    .ev-ai-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .ev-ai-product-card {
      background: var(--ev-card-bg);
      border: 1px solid var(--ev-card-border);
      border-radius: 16px; padding: 10px;
      display: flex; flex-direction: column; gap: 10px;
      transition: background 0.2s;
    }
    .ev-ai-product-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }

    .ev-ai-img-box {
      width: 100%; aspect-ratio: 1; border-radius: 12px;
      background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
      display: flex; align-items: center; justify-content: center; padding: 10px;
    }
    .ev-ai-img-box img { max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(0 10px 10px rgba(0,0,0,0.5)); }

    .ev-ai-card-info { display: flex; flex-direction: column; gap: 4px; }
    .ev-ai-card-title { font-size: 11px; font-weight: 500; color: var(--ev-text-main); line-height: 1.3; font-family: var(--ev-font); }
    .ev-ai-card-price { font-size: 11px; color: var(--ev-text-muted); margin-bottom: 4px; font-family: var(--ev-font);}

    .ev-ai-actions-row { display: flex; align-items: center; gap: 6px; }
    .ev-ai-btn-add {
      flex: 1; padding: 8px 0; border: none; border-radius: 20px;
      background: var(--ev-accent); color: #000; font-size: 10px; font-weight: 700;
      letter-spacing: 0.5px; cursor: pointer; transition: opacity 0.2s; font-family: var(--ev-font);
    }
    .ev-ai-btn-add:hover { opacity: 0.8; box-shadow: 0 0 10px var(--ev-accent-glow); }

    .ev-ai-btn-star {
      width: 28px; height: 28px; border-radius: 50%;
      background: rgba(255,255,255,0.1); border: none; color: var(--ev-text-muted);
      display: flex; align-items: center; justify-content: center; cursor: pointer;
    }
    .ev-ai-btn-star svg { width: 12px; height: 12px; fill: currentColor; }
    .ev-ai-btn-star:hover { color: var(--ev-text-main); background: rgba(255,255,255,0.2); }

    /* -------------------------------------- */
    /* 7. BOTTOM WAVE & RECORDING STATUS      */
    /* -------------------------------------- */
    .ev-ai-bottom-glass {
      border-top: 1px solid var(--ev-panel-border);
      padding: 16px 24px;
      background: rgba(15, 18, 22, 0.4);
      display: flex; flex-direction: column; gap: 12px;
    }

    .ev-ai-big-wave {
      width: 100%; height: 40px;
      display: flex; align-items: center; justify-content: space-between; gap: 2px;
    }
    .ev-ai-big-wave-bar {
      flex: 1; border-radius: 2px;
      background: linear-gradient(180deg, #00f2fe 0%, #a200ff 100%);
      opacity: 0.8;
      animation: ev-big-bounce 1.2s infinite ease-in-out alternate;
    }
    .ev-ai-big-wave-bar:nth-child(2n) { background: linear-gradient(180deg, #1fdf64 0%, #00f2fe 100%); height: 80%; animation-duration: 0.9s; }
    .ev-ai-big-wave-bar:nth-child(3n) { height: 50%; animation-duration: 1.5s; }
    .ev-ai-big-wave-bar:nth-child(4n) { height: 90%; animation-duration: 1.1s; }
    .ev-ai-big-wave-bar:nth-child(5n) { height: 40%; animation-duration: 0.8s; }

    @keyframes ev-big-bounce { 0% { transform: scaleY(0.2); } 100% { transform: scaleY(1); } }

    .ev-ai-recording-status {
      display: flex; justify-content: space-between; align-items: center;
      font-size: 11px; color: var(--ev-text-muted); font-weight: 500; letter-spacing: 0.5px;
    }
    .ev-ai-rec-text { display: flex; align-items: center; gap: 6px; }
  </style>

