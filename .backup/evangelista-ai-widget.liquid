  <!-- ========================================== -->
  <!-- VAPI WEB SDK (UMD Build for Custom UI)     -->
  <!-- ========================================== -->
  <script>
    // Load the Vapi Web SDK UMD build — exposes global `Vapi` constructor.
    // This is NOT the html-script-tag (which creates its own button UI).
    // UMD build gives us: new Vapi(key) → vapi.start(assistantId) → vapi.on(event, cb)
    (function(d, t) {
      var g = d.createElement(t), s = d.getElementsByTagName(t)[0];
      g.src = 'https://cdn.jsdelivr.net/gh/balacodeio/Vapi-Web-UMD@latest/dist/latest/vapi-web-bundle.min.js';
      g.defer = true;
      g.async = true;
      s.parentNode.insertBefore(g, s);

      g.onload = function() {
        console.log('[EvangelistaAI] Vapi UMD SDK loaded. Vapi constructor available:', typeof Vapi);
        if (typeof Vapi === 'function') {
          window.evAiInit();
        } else {
          console.error('[EvangelistaAI] FATAL: Vapi constructor not found after UMD load.');
        }
      };
      g.onerror = function() {
        console.error('[EvangelistaAI] FATAL: Failed to load Vapi UMD SDK from CDN.');
      };
    })(document, 'script');
  </script>

  <!-- ========================================== -->
  <!-- JAVASCRIPT STATE MACHINE & LOGIC           -->
  <!-- ========================================== -->
  <script>
    // ==========================================
    // VAPI CONFIGURATION (REQUIRED)
    // ==========================================
    // Paste your Vapi Public Key and Assistant ID below.
    var EV_VAPI_PUBLIC_KEY = '07474656---------';
    var EV_VAPI_ASSISTANT_ID = '64e9aec9----------';

    window.evAiInit = function() {
      // --------------------------------------
      // 0. GENERATE WAVE BARS (replaces document.write)
      // --------------------------------------
      var waveContainer = document.getElementById('ev-ai-wave');
      if (waveContainer) {
        for (var i = 0; i < 30; i++) {
          var bar = document.createElement('div');
          bar.className = 'ev-ai-big-wave-bar';
          bar.style.animationDelay = (Math.random() * 1.5).toFixed(2) + 's';
          waveContainer.appendChild(bar);
        }
      }

      // --------------------------------------
      // 1. REACTIVE STATE MANAGER
      // --------------------------------------
      var state = {
        isOpen: false,
        vapiStatus: 'disconnected', // disconnected | connecting | listening | speaking
        view: 'search_results',
        products: [],
        callStartTime: null,
        timerInterval: null
      };

      // --------------------------------------
      // 2. DOM ELEMENT BINDINGS
      // --------------------------------------
      var els = {
        launcherWrap: document.getElementById('ev-ai-launcher-wrapper'),
        launcherBtn:  document.querySelector('.ev-ai-launcher-btn'),
        panel:        document.getElementById('ev-ai-panel'),
        stage:        document.getElementById('ev-ai-stage'),
        orbText:      document.querySelector('.ev-ai-orb-text'),
        statusBadge:  document.querySelector('.ev-ai-status-badge'),
        closeBtn:     document.querySelector('.ev-ai-close-btn'),
        recLabel:     document.getElementById('ev-ai-rec-label'),
        timer:        document.getElementById('ev-ai-timer')
      };

      if (!els.panel || !els.launcherBtn) {
        console.error('[EvangelistaAI] Widget DOM elements not found. Aborting.');
        return;
      }

      // --------------------------------------
      // 3. CALL TIMER
      // --------------------------------------
      function startTimer() {
        state.callStartTime = Date.now();
        state.timerInterval = setInterval(function() {
          if (!state.callStartTime) return;
          var elapsed = Math.floor((Date.now() - state.callStartTime) / 1000);
          var mins = String(Math.floor(elapsed / 60)).padStart(2, '0');
          var secs = String(elapsed % 60).padStart(2, '0');
          if (els.timer) els.timer.textContent = mins + ':' + secs;
        }, 1000);
      }

      function stopTimer() {
        if (state.timerInterval) clearInterval(state.timerInterval);
        state.timerInterval = null;
        state.callStartTime = null;
        if (els.timer) els.timer.textContent = '00:00';
      }

      // --------------------------------------
      // 4. UI RENDER ENGINE
      // --------------------------------------
      function render() {
        // --- Drawer Visibility (using CSS class) ---
        if (state.isOpen) {
          els.panel.classList.add('ev-open');
          els.launcherWrap.style.opacity = '0';
          els.launcherWrap.style.pointerEvents = 'none';
          els.launcherWrap.style.transform = 'scale(0.8)';
        } else {
          els.panel.classList.remove('ev-open');
          els.launcherWrap.style.opacity = '1';
          els.launcherWrap.style.pointerEvents = 'all';
          els.launcherWrap.style.transform = 'scale(1)';
        }

        // --- Status Indicators ---
        var statusMap = {
          disconnected: { orb: 'TAP TO TALK', badge: 'OFFLINE', badgeColor: '#8b96a5', badgeBg: 'rgba(255,255,255,0.05)', dotStyle: 'background:#8b96a5;box-shadow:none;' },
          connecting:   { orb: 'CONNECTING...', badge: 'CONNECTING', badgeColor: '#f0a500', badgeBg: 'rgba(240,165,0,0.1)', dotStyle: 'background:#f0a500;box-shadow:0 0 8px #f0a500;' },
          listening:    { orb: 'LISTENING...', badge: 'ACTIVE', badgeColor: 'var(--ev-accent)', badgeBg: 'rgba(31,223,100,0.1)', dotStyle: '' },
          speaking:     { orb: 'SPEAKING...', badge: 'ACTIVE', badgeColor: 'var(--ev-accent)', badgeBg: 'rgba(31,223,100,0.1)', dotStyle: '' }
        };
        var s = statusMap[state.vapiStatus] || statusMap.disconnected;
        els.orbText.textContent = s.orb;
        els.statusBadge.innerHTML = s.badge + ' <span class="ev-ai-status-dot" style="' + (s.dotStyle || '') + '"></span>';
        els.statusBadge.style.color = s.badgeColor;
        els.statusBadge.style.background = s.badgeBg;

        // --- Recording Label & Transcript ---
        if (els.recLabel) {
          if (state.vapiStatus === 'listening') els.recLabel.textContent = 'LISTENING...';
          else if (state.vapiStatus === 'speaking') els.recLabel.textContent = 'JOHN IS SPEAKING...';
          else if (state.vapiStatus === 'connecting') els.recLabel.textContent = 'CONNECTING...';
          else els.recLabel.textContent = 'READY';
        }

        var transcriptEl = document.getElementById('ev-ai-transcript-text');
        if (transcriptEl) {
          transcriptEl.textContent = state.transcript || 'How can I help you today?';
        }

        // --- Dynamic Product Stage ---
        renderStage();

        // --- Delegate click events ---
        els.stage.onclick = function(e) {
          var btn = e.target.closest('[data-ev-action]');
          if (!btn) return;
          var evAction = btn.getAttribute('data-ev-action');
          var id = btn.getAttribute('data-id') || '';
          var variantId = btn.getAttribute('data-variant') || '';
          var qty = parseInt(btn.getAttribute('data-qty') || '1', 10);

          if (evAction === 'add-to-cart') addToShopifyCart(variantId || id, qty);
          else if (evAction === 'remove-from-cart') updateShopifyCart(id, 0);
          else if (evAction === 'update-qty') updateShopifyCart(id, qty);
          else if (evAction === 'open-product') openProductById(id);
        };
      }

      // --------------------------------------
      // 5. STAGE RENDERER (separated for clarity)
      // --------------------------------------
      function renderStage() {
        // === Search Results View ===
        if (state.view === 'search_results' && state.products.length > 0) {
          var html = '';
          state.products.forEach(function(p, idx) {
            var imgSrc = (p.images && p.images[0]) || p.image || 'https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-product-1_large.png';
            var priceText = (typeof p.price === 'number') ? ('$' + p.price.toFixed(2)) : (p.price || '$0.00');
            var stockLabel = p.in_stock === false ? '<span style="color:#ff4d4d;font-size:9px;">OUT OF STOCK</span>' : '';
            var productId = p.product_id || p.id || '';
            html += '<div class="ev-ai-product-card" id="ev-card-' + idx + '">' +
              '<div class="ev-ai-img-box">' +
                '<img src="' + imgSrc + '" alt="' + (p.title || '') + '">' +
              '</div>' +
              '<div class="ev-ai-card-info">' +
                '<span class="ev-ai-card-title">' + (p.title || 'Product') + '</span>' +
                '<span class="ev-ai-card-price">' + priceText + ' ' + (p.currency || '') + ' ' + stockLabel + '</span>' +
                '<div class="ev-ai-actions-row">' +
                  '<button class="ev-ai-btn-add" data-ev-action="open-product" data-id="' + productId + '">VIEW</button>' +
                '</div>' +
              '</div>' +
            '</div>';
          });
          els.stage.style.display = 'grid';
          els.stage.innerHTML = html;
        }
        // === Product Detail View ===
        else if (state.view === 'product_detail' && state.products.length > 0) {
          var p = state.products[0];
          var imgSrc = (p.images && p.images[0]) || p.image || '';
          var priceText = (typeof p.price === 'number') ? ('$' + p.price.toFixed(2)) : (p.price || '');
          var variants = p.variants || [];
          var productId = p.product_id || p.id || '';

          var variantHtml = '';
          if (variants.length > 0) {
            variantHtml = '<div style="margin:12px 0;display:flex;flex-wrap:wrap;gap:6px;justify-content:center;">';
            variants.forEach(function(v) {
              var vId = v.variant_id || v.id || '';
              var vTitle = v.title || 'Default';
              var vAvail = v.available !== false;
              variantHtml += '<button class="ev-ai-btn-add" data-ev-action="add-to-cart" data-variant="' + vId + '" data-qty="1" ' +
                'style="font-size:10px;padding:6px 10px;' + (vAvail ? '' : 'opacity:0.4;cursor:not-allowed;') + '"' +
                (vAvail ? '' : ' disabled') + '>' + vTitle + '</button>';
            });
            variantHtml += '</div>';
          } else {
            // No variants — use product ID as variant ID for simple products
            variantHtml = '<button class="ev-ai-btn-add" data-ev-action="add-to-cart" data-variant="' + productId + '" data-qty="1" style="font-size:14px;padding:12px;width:100%;margin-top:12px;">ADD TO CART</button>';
          }

          els.stage.style.display = 'flex';
          els.stage.innerHTML = '<div style="background:var(--ev-card-bg);border-radius:16px;padding:20px;text-align:center;border:1px solid var(--ev-card-border);width:100%;">' +
            (imgSrc ? '<img src="' + imgSrc + '" style="width:100%;max-height:200px;object-fit:contain;filter:drop-shadow(0 10px 10px rgba(0,0,0,0.5));margin-bottom:12px;">' : '') +
            '<h4 style="color:#fff;font-size:15px;margin-bottom:6px;">' + (p.title || 'Product') + '</h4>' +
            '<p style="color:var(--ev-text-muted);font-size:13px;margin-bottom:4px;">' + priceText + ' ' + (p.currency || '') + '</p>' +
            (p.short_description ? '<p style="color:var(--ev-text-muted);font-size:11px;margin-bottom:8px;">' + p.short_description + '</p>' : '') +
            variantHtml +
            '<button data-ev-action="back-to-results" style="background:none;border:1px solid var(--ev-panel-border);color:var(--ev-text-muted);padding:8px 16px;border-radius:20px;font-size:10px;cursor:pointer;margin-top:8px;font-family:var(--ev-font);">← BACK TO RESULTS</button>' +
          '</div>';
          // Handle "back" separately
          els.stage.querySelector('[data-ev-action="back-to-results"]').onclick = function() {
            if (state.lastSearchProducts && state.lastSearchProducts.length > 0) {
              state.products = state.lastSearchProducts;
              state.view = 'search_results';
            } else {
              state.products = [];
              state.view = 'search_results';
            }
            render();
          };
        }
        // === Cart View ===
        else if (state.view === 'cart') {
          if (state.cartItems && state.cartItems.length > 0) {
            var cartHtml = '<div style="width:100%;"><h3 style="color:#fff;font-size:14px;margin-bottom:12px;">Your Cart</h3>';
            var cartTotal = 0;
            state.cartItems.forEach(function(item) {
              var linePrice = (item.line_price || item.price || 0) / 100;
              cartTotal += linePrice;
              cartHtml += '<div style="display:flex;gap:10px;align-items:center;padding:10px;background:var(--ev-card-bg);border:1px solid var(--ev-card-border);border-radius:12px;margin-bottom:8px;">' +
                (item.image ? '<img src="' + item.image + '" style="width:50px;height:50px;object-fit:cover;border-radius:8px;">' : '') +
                '<div style="flex:1;">' +
                  '<p style="color:#fff;font-size:12px;margin:0;">' + (item.title || 'Item') + '</p>' +
                  '<p style="color:var(--ev-text-muted);font-size:10px;margin:2px 0 0 0;">' + (item.variant_title || '') + ' × ' + item.quantity + '</p>' +
                  '<p style="color:var(--ev-accent);font-size:11px;margin:2px 0 0 0;">$' + linePrice.toFixed(2) + '</p>' +
                '</div>' +
                '<div style="display:flex;gap:4px;">' +
                  '<button class="ev-ai-btn-star" data-ev-action="update-qty" data-id="' + item.key + '" data-qty="' + Math.max(0, item.quantity - 1) + '" title="Decrease">−</button>' +
                  '<button class="ev-ai-btn-star" data-ev-action="update-qty" data-id="' + item.key + '" data-qty="' + (item.quantity + 1) + '" title="Increase">+</button>' +
                  '<button class="ev-ai-btn-star" data-ev-action="remove-from-cart" data-id="' + item.key + '" title="Remove" style="color:#ff4d4d;">✕</button>' +
                '</div>' +
              '</div>';
            });
            cartHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-top:1px solid var(--ev-panel-border);margin-top:8px;">' +
              '<span style="color:#fff;font-size:13px;font-weight:600;">Total</span>' +
              '<span style="color:var(--ev-accent);font-size:15px;font-weight:700;">$' + cartTotal.toFixed(2) + '</span>' +
            '</div>' +
            '<a href="/checkout" style="display:block;text-align:center;padding:12px;background:var(--ev-accent);color:#000;font-weight:700;font-size:12px;border-radius:20px;text-decoration:none;letter-spacing:0.5px;font-family:var(--ev-font);">PROCEED TO CHECKOUT</a>' +
            '</div>';
            els.stage.style.display = 'flex';
            els.stage.innerHTML = cartHtml;
          } else {
            els.stage.innerHTML = '<p style="color:var(--ev-text-muted);text-align:center;padding:20px 0;font-size:12px;">Your cart is empty.</p>';
          }
        }
        // === Empty State ===
        else {
          els.stage.innerHTML = '<p style="color:var(--ev-text-muted);text-align:center;padding:20px 0;font-size:12px;">Ask the AI to find some gear!</p>';
        }
      }

      // --------------------------------------
      // 6. TOAST NOTIFICATION SYSTEM
      // --------------------------------------
      function showToast(message, type) {
        type = type || 'success';
        var toast = document.createElement('div');
        var bgColor = type === 'success' ? 'rgba(31,223,100,0.95)' : type === 'error' ? 'rgba(255,77,77,0.95)' : 'rgba(240,165,0,0.95)';
        toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:2147483647;padding:12px 20px;border-radius:8px;color:#000;font-family:var(--ev-font);font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.4);transform:translateY(-20px);opacity:0;transition:all 0.3s;background:' + bgColor + ';max-width:300px;';
        toast.textContent = message;
        document.body.appendChild(toast);
        // Animate in
        requestAnimationFrame(function() {
          toast.style.transform = 'translateY(0)';
          toast.style.opacity = '1';
        });
        // Animate out after 3s
        setTimeout(function() {
          toast.style.transform = 'translateY(-20px)';
          toast.style.opacity = '0';
          setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 350);
        }, 3000);
      }

      // --------------------------------------
      // 7. SHOPIFY CART API INTEGRATION
      // --------------------------------------
      function addToShopifyCart(variantId, quantity) {
        if (!variantId) { showToast('No variant selected.', 'error'); return; }

        // Shopify cart endpoints require strictly numeric Variant IDs.
        // If it's a GID string (e.g. "gid://shopify/ProductVariant/123456"), extract the numbers.
        if (typeof variantId === 'string') {
          var match = variantId.match(/(\d+)$/);
          if (match) {
             variantId = match[1];
          }
        }

        quantity = quantity || 1;
        console.log('[EvangelistaAI] Adding to Shopify cart: variant=' + variantId + ' qty=' + quantity);
        showToast('Adding to cart...', 'info');

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: quantity })
        })
        .then(function(res) {
          if (!res.ok) throw new Error('Shopify returned ' + res.status);
          return res.json();
        })
        .then(function(data) {
          console.log('[EvangelistaAI] Cart add success:', data);
          showToast('Added to cart! ✓', 'success');
          // Update Shopify theme cart count if possible
          updateThemeCartCount();
        })
        .catch(function(err) {
          console.error('[EvangelistaAI] Cart add error:', err);
          showToast('Failed to add to cart. Please try again.', 'error');
        });
      }

      function updateShopifyCart(lineKey, quantity) {
        if (!lineKey) return;
        console.log('[EvangelistaAI] Updating cart: key=' + lineKey + ' qty=' + quantity);
        var updates = {};
        updates[lineKey] = quantity;

        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ updates: updates })
        })
        .then(function(res) {
          if (!res.ok) throw new Error('Shopify returned ' + res.status);
          return res.json();
        })
        .then(function(data) {
          console.log('[EvangelistaAI] Cart update success:', data);
          if (quantity === 0) showToast('Removed from cart.', 'success');
          else showToast('Cart updated! ✓', 'success');
          // Refresh cart view if currently showing
          if (state.view === 'cart') fetchAndShowCart();
          updateThemeCartCount();
        })
        .catch(function(err) {
          console.error('[EvangelistaAI] Cart update error:', err);
          showToast('Failed to update cart.', 'error');
        });
      }

      function fetchAndShowCart() {
        fetch('/cart.js')
        .then(function(res) { return res.json(); })
        .then(function(cart) {
          console.log('[EvangelistaAI] Cart fetched:', cart);
          state.cartItems = (cart.items || []).map(function(item) {
            return {
              key: item.key,
              title: item.title,
              variant_title: item.variant_title || '',
              quantity: item.quantity,
              price: item.price,
              line_price: item.line_price || (item.price * item.quantity),
              image: item.image || (item.featured_image && item.featured_image.url) || ''
            };
          });
          state.view = 'cart';
          render();
        })
        .catch(function(err) {
          console.error('[EvangelistaAI] Failed to fetch cart:', err);
          showToast('Could not load cart.', 'error');
        });
      }

      function updateThemeCartCount() {
        // Try to update the theme's cart count badge(s)
        try {
          fetch('/cart.js')
          .then(function(res) { return res.json(); })
          .then(function(cart) {
            var countEls = document.querySelectorAll('[data-cart-count], .cart-count-bubble span, .cart-count, .js-cart-count');
            countEls.forEach(function(el) { el.textContent = cart.item_count; });
          });
        } catch(e) { /* Theme might not have these elements */ }
      }

      // --------------------------------------
      // 8. PRODUCT DETAIL FETCHING
      // --------------------------------------
      // Cache last search results for back-navigation and open_product lookups
      function openProductById(productId) {
        if (!productId) return;
        console.log('[EvangelistaAI] Opening product:', productId);

        // Optional numeric ID parsing for lookup flexibility
        var numericProductId = typeof productId === 'string' && productId.indexOf('gid://') !== -1 ? productId.split('/').pop() : productId;

        // First, check if we have this product in our current results
        var found = null;
        state.products.forEach(function(p) {
          var pId = p.product_id || p.id || '';
          var pNumId = typeof pId === 'string' && pId.indexOf('gid://') !== -1 ? pId.split('/').pop() : pId;
          if (pId === productId || pNumId === numericProductId) found = p;
        });

        // Save current results for back-navigation
        if (state.view === 'search_results' && state.products.length > 0) {
          state.lastSearchProducts = state.products.slice();
        }

        if (found) {
          state.products = [found];
          state.view = 'product_detail';
          render();
        } else {
          // Fetch from our backend API
          state.view = 'product_detail';
          state.products = [{ product_id: productId, title: 'Loading...', price: '' }];
          render();
          // Try backend product endpoint
          fetch('/api/product/' + encodeURIComponent(productId))
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data && data.item) {
              state.products = [data.item];
            } else if (data) {
              state.products = [data];
            }
            render();
          })
          .catch(function(err) {
            console.warn('[EvangelistaAI] Product fetch failed, using cached data:', err);
          });
        }
      }

      // --------------------------------------
      // 9. NAVIGATION HANDLER
      // --------------------------------------
      function navigateTo(payload) {
        if (!payload) return;
        var pageMap = {
          'home': '/',
          'cart': '/cart',
          'search': '/search',
          'collection': '/collections',
          'collections': '/collections'
        };

        var url = payload.url || pageMap[payload.page] || null;
        if (!url) {
          console.warn('[EvangelistaAI] Unknown navigation target:', payload);
          return;
        }

        // If it's cart page, use our widget's cart view instead of navigating
        if (payload.page === 'cart') {
          fetchAndShowCart();
          return;
        }

        console.log('[EvangelistaAI] Navigating to:', url);
        // Use standard navigation — safe across all Shopify themes
        window.location.href = url;
      }

      // --------------------------------------
      // 10. ACTION ROUTER (Production)
      // --------------------------------------
      window.handleAction = function(action) {
        if (!action || !action.type) {
          console.warn('[EvangelistaAI] Invalid action received:', action);
          return;
        }
        console.log('[EvangelistaAI] Action received:', action);
        var payload = action.payload || {};

        switch (action.type) {
          case 'search_products':
            state.view = 'search_results';
            state.products = payload.candidates || [];
            // Cache for open_product back-navigation
            state.lastSearchProducts = state.products.slice();
            break;

          case 'open_product':
            var pid = payload.product_id || payload.id || '';

            // If the backend sent full product details (e.g. variants, images exists), render it directly!
            if (payload.title && (payload.variants || payload.images || payload.price)) {
              console.log('[EvangelistaAI] Received full product payload, rendering directly.');
              state.products = [payload];
              state.view = 'product_detail';
              render();
              return;
            }

            // Otherwise, fallback to lookup in cache by ID
            if (pid) openProductById(pid);
            return;

          case 'add_to_cart':
            var vid = payload.variant_id || '';
            var qty = payload.quantity || 1;
            if (vid) {
              addToShopifyCart(vid, qty);
            } else {
              console.warn('[EvangelistaAI] add_to_cart missing variant_id');
              showToast('Cannot add — variant not specified.', 'error');
            }
            break;

          case 'update_cart':
            var lineKey = payload.line_id || '';
            var newQty = (payload.quantity !== undefined) ? payload.quantity : 1;
            if (lineKey) {
              updateShopifyCart(lineKey, newQty);
            } else {
              showToast('Cannot update — cart item not specified.', 'error');
            }
            break;

          case 'show_cart':
            fetchAndShowCart();
            return; // fetchAndShowCart calls render() itself

          case 'navigate':
            navigateTo(payload);
            break;

          default:
            console.warn('[EvangelistaAI] Unknown action type:', action.type);
        }
        render();
      };

      // Manual UI cart button (for product cards without variant selector)
      window.evAiCart = function(variantId) {
        if (variantId) addToShopifyCart(variantId, 1);
      };

      // --------------------------------------
      // 11. VAPI SDK INITIALIZATION (UMD Build)
      // --------------------------------------
      // The UMD build gives us a global `Vapi` constructor class.
      // new Vapi(publicKey) creates a headless instance — NO UI is created.
      // We control everything: .start(assistantId), .stop(), .on(event, cb)
      var vapiInstance = new Vapi(EV_VAPI_PUBLIC_KEY);
      window.vapiInstance = vapiInstance;
      console.log('[EvangelistaAI] Vapi instance created (headless, no built-in UI).');

      // --------------------------------------
      // 12. VAPI EVENT BINDINGS
      // --------------------------------------
      vapiInstance.on('call-start', function() {
        console.log('[EvangelistaAI] Call started — microphone active.');
        state.vapiStatus = 'listening';
        state.isOpen = true;
        state.transcript = '';
        startTimer();
        render();
      });

      vapiInstance.on('call-end', function() {
        console.log('[EvangelistaAI] Call ended.');
        state.vapiStatus = 'disconnected';
        stopTimer();
        render();
      });

      vapiInstance.on('speech-start', function() {
        state.vapiStatus = 'speaking';
        render();
      });

      vapiInstance.on('speech-end', function() {
        state.vapiStatus = 'listening';
        render();
      });

      vapiInstance.on('message', function(message) {
        console.log('[EvangelistaAI] Vapi message:', message);

        // Handle real-time transcripts updates
        if (message.type === 'transcript' && message.transcriptType === 'final') {
          console.log('[EvangelistaAI] Transcript [' + message.role + ']: ' + message.transcript);
          state.transcript = message.transcript;
          render();
        }

        // --- ROBUST ACTION EXTRACTION ---
        // Vapi sends tool results in multiple formats and deeply nested arrays.
        // A recursive deep search ensures we NEVER miss the backend's {"action": {"type": "..."}}
        var actionObj = null;

        function findActionDeep(obj, depth) {
          if (!obj || typeof obj !== 'object' || depth > 5) return null;

          // Found exact shape!
          if (obj.action && obj.action.type && obj.action.payload) return obj.action;

          if (Array.isArray(obj)) {
            for (var i=0; i < obj.length; i++) {
              var f = findActionDeep(obj[i], depth + 1);
              if (f) return f;
            }
            return null;
          }

          var keys = ['message', 'toolCallResult', 'results', 'result', 'toolWithToolCallList', 'toolCall', 'function', 'arguments', 'parameters'];
          for (var j=0; j < keys.length; j++) {
            var val = obj[keys[j]];
            if (val) {
              if (typeof val === 'string' && (val.indexOf('{') === 0 || val.indexOf('[') === 0)) {
                try { val = JSON.parse(val); } catch(e) {}
              }
              var found = findActionDeep(val, depth + 1);
              if (found) return found;
            }
          }
          return null;
        }

        actionObj = findActionDeep(message, 0);

        // Pattern Fallback: If Vapi is calling a tool but no "action" envelope was attached, we can use the call itself.
        // But only if we haven't already found the rich action response.
        if (!actionObj && message.type === 'function-call' && message.functionCall) {
            actionObj = {
                type: message.functionCall.name,
                payload: message.functionCall.parameters || {}
            };
        }

        // Dispatch if we found an action
        if (actionObj) {
          console.log('[EvangelistaAI] Extracted action from Vapi message:', actionObj);
          window.handleAction(actionObj);
        }
      });

      vapiInstance.on('error', function(e) {
        console.error('[EvangelistaAI] Vapi error:', e);
        state.vapiStatus = 'disconnected';
        showToast('Connection error. Please try again.', 'error');
        render();
      });

      // --------------------------------------
      // 13. CUSTOM LAUNCHER BUTTON EVENTS
      // --------------------------------------
      els.launcherBtn.addEventListener('click', function() {
        console.log('[EvangelistaAI] Launcher clicked. Starting Vapi call...');
        state.vapiStatus = 'connecting';
        state.isOpen = true;
        render();
        // Pass the assistant ID to start() — required by the UMD/Web SDK
        vapiInstance.start(EV_VAPI_ASSISTANT_ID);
      });

      if (els.closeBtn) {
        els.closeBtn.addEventListener('click', function() {
          console.log('[EvangelistaAI] Close button clicked. Ending call...');
          vapiInstance.stop();
          state.isOpen = false;
          state.vapiStatus = 'disconnected';
          state.products = [];
          state.cartItems = [];
          state.lastSearchProducts = [];
          state.transcript = '';
          stopTimer();
          render();
        });
      }

      // Initial render (panel hidden, launcher visible)
      render();

      console.log('[EvangelistaAI] Widget initialized and ready. Phase 3 + Phase 4 active.');
    };
  </script>

</div>
